+#include <twm.h>
+
+extern bool STANIX_CreateWindow(SDL_VideoDevice *_this, SDL_Window *window, SDL_PropertiesID create_props)
+{
+    SDL_WindowData *data = (struct SDL_WindowData *)SDL_calloc(1, sizeof(SDL_WindowData));
+    data->window = twm_create_window("sdl window", window->w, window->h, TWM_NULL);
+    if (data->window == TWM_NULL) {
+        SDL_free(data);
+        return false;
+    }
+    window->internal = data;
+
+    // TODO : do various flags here
+    if (window->flags & SDL_WINDOW_BORDERLESS) {
+    }
+    return true;
+}
+
+extern void STANIX_DestroyWindow(SDL_VideoDevice *_this, SDL_Window *window)
+{
+    SDL_WindowData *data = (struct SDL_WindowData *)window->internal;
+    twm_destroy_window(data->window);
+    SDL_free(data);
+    window->internal = NULL;
+}
+
+void STANIX_SetWindowTitle(SDL_VideoDevice *_this, SDL_Window *window)
+{
+    SDL_WindowData *data = (struct SDL_WindowData *)window->internal;
+    twm_set_window_title(data->window, window->title);
+}
+
+bool STANIX_SetWindowPosition(SDL_VideoDevice *_this, SDL_Window *window)
+{
+    SDL_WindowData *data = (struct SDL_WindowData *)window->internal;
+    return twm_window_move(data->window, window->x, window->y) >= 0;
+}
+
+void STANIX_SetWindowSize(SDL_VideoDevice *_this, SDL_Window *window)
+{
+    SDL_WindowData *data = (struct SDL_WindowData *)window->internal;
+    twm_window_resize(data->window, window->w, window->h);
+}
+
+void STANIX_SetWindowBordered(SDL_VideoDevice *_this, SDL_Window *window, bool bordered)
+{
+    SDL_WindowData *data = (struct SDL_WindowData *)window->internal;
+    twm_set_window_attr(data->window, bordered ? TWM_ADD_ATTR : TWM_REMOVE_ATTR, TWM_ATTR_DECORED);
+}
+
+void STANIX_SetWindowResizable(SDL_VideoDevice *_this, SDL_Window *window, bool resizable)
+{
+    SDL_WindowData *data = (struct SDL_WindowData *)window->internal;
+    twm_set_window_attr(data->window, resizable ? TWM_ADD_ATTR : TWM_REMOVE_ATTR, TWM_ATTR_RESIZABLE);
+}
+
+#endif // SDL_VIDEO_DRIVER_STANIX
