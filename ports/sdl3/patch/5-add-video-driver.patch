+#include "SDL_internal.h"
+
+#ifdef SDL_VIDEO_DRIVER_STANIX
+
+#include "../SDL_sysvideo.h"
+#include "SDL_stanixframebuffer.h"
+#include "SDL_stanixvideo.h"
+#include "SDL_stanixwindow.h"
+#include <unistd.h>
+#include <sys/mman.h>
+#include <twm.h>
+
+bool STANIX_CreateWindowFramebuffer(SDL_VideoDevice *_this, SDL_Window *window, SDL_PixelFormat *format, void **pixels, int *pitch)
+{
+    SDL_WindowData *data = window->internal;
+    const SDL_DisplayMode *mode;
+
+    // destroy any already created framebuffer
+    STANIX_DestroyWindowFramebuffer(_this, window);
+
+    int fd;
+    if (twm_get_window_fb(data->window, &fd, &data->fb_info) < 0) {
+        SDL_SetError("Failed to fetch framebuffer");
+        return false;
+    }
+
+    data->framebuffer = mmap(NULL, data->fb_info.pitch * data->fb_info.height, PROT_WRITE, MAP_SHARED, fd, 0);
+    data->backbuffer  = SDL_malloc(data->fb_info.pitch * data->fb_info.height);
+    close(fd);
+
+    mode = SDL_GetCurrentDisplayMode(SDL_GetDisplayForWindow(window));
+    *format = mode->format;
+    *pixels = data->backbuffer;
+    *pitch = data->fb_info.pitch;
+
+    return true;
+}
+
+bool STANIX_UpdateWindowFramebuffer(SDL_VideoDevice *_this, SDL_Window *window, const SDL_Rect *rects, int numrects)
+{
+    SDL_WindowData *data = window->internal;
+    // TODO : respect rects
+    (void)rects;
+    (void)numrects;
+    memcpy(data->framebuffer, data->backbuffer, data->fb_info.pitch * data->fb_info.height);
+    return twm_redraw_window(data->window, 0, 0, TWM_WHOLE_WIDTH, TWM_WHOLE_HEIGHT) >= 0;
+}
+
+void STANIX_DestroyWindowFramebuffer(SDL_VideoDevice *_this, SDL_Window *window)
+{
+    SDL_WindowData *data = window->internal;
+    if (data->framebuffer) {
+        munmap(data->framebuffer, data->fb_info.pitch * data->fb_info.height);
+        data->framebuffer = NULL;
+    }
+    if (data->backbuffer) {
+        free(data->backbuffer);
+        data->backbuffer = NULL;
+    }
+}
+
+#endif // SDL_VIDEO_DRIVER_STANIX
