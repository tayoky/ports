+static uint8_t translate_mouse_button(long stanix_button) {
+    switch (stanix_button) {
+    case INPUT_KEY_MOUSE_LEFT:
+    default:
+        return SDL_BUTTON_LEFT;
+    case INPUT_KEY_MOUSE_MIDDLE:
+        return SDL_BUTTON_MIDDLE;
+    case INPUT_KEY_MOUSE_RIGHT:
+        return SDL_BUTTON_RIGHT;
+    }
+}
+
+static bool is_mouse_key(long key) {
+    if (key == INPUT_KEY_MOUSE_LEFT
+        || key == INPUT_KEY_MOUSE_MIDDLE
+        || key == INPUT_KEY_MOUSE_RIGHT) {
+        return true;
+    }
+    return false;
+}
+
+static SDL_Window *get_window(twm_window_t twm_window) {
+    int count;
+    SDL_Window **windows = SDL_GetWindows(&count);
+    for (int i=0; i<count; i++) {
+        SDL_Window *window = windows[i];
+        SDL_WindowData *data = (struct SDL_WindowData *)window->internal;
+        if (data->window == twm_window) {
+            return window;
+        }
+    }
+    return NULL;
+}
+
+static void handle_input_event(twm_event_input_t *event) {
+    switch (event->type) {
+    case TWM_INPUT_KEY:
+        if (is_mouse_key(event->key.key)) {
+            SDL_Mouse *mouse = SDL_GetMouse();
+            SDL_SendMouseButton(0, mouse->focus, SDL_DEFAULT_MOUSE_ID, translate_mouse_button(event->key.key), event->key.flags & TWM_INPUT_PRESS);
+        } else {
+            // TODO : focus the correct window
+            printf("send scancode=%d keycode=%d press=%d\n", translate_scancode(event->key.scancode), translate_keycode(event->key.key), event->key.flags & TWM_INPUT_PRESS);
+            SDL_SendKeyboardKey(0, SDL_DEFAULT_KEYBOARD_ID, translate_scancode(event->key.scancode), translate_keycode(event->key.key), event->key.flags & TWM_INPUT_PRESS);
+        }
+        break;
+    case TWM_INPUT_MOVE:
+        //SDL_SendMouseMotion(0, mouse->focus, SDL_DEFAULT_MOUSE_ID, false, (float)x, (float)y);
+        break;
+    }
+}
+
+static void handle_window_event(twm_event_window_t *event) {
+    SDL_Window *window = get_window(event->window);
+    if (!window) return;
+
+    SDL_EventType type = 0;
+    switch (event->base.type) {
+    case TWM_EVENT_WINDOW_CLOSED:
+        type = SDL_EVENT_WINDOW_CLOSE_REQUESTED;
+        break;
+    case TWM_EVENT_WINDOW_RESIZED:
+        type = SDL_EVENT_WINDOW_RESIZED;
+        // TODO : send new size
+        break;
+    case TWM_EVENT_WINDOW_MAXIMIZED:
+        type = SDL_EVENT_WINDOW_MAXIMIZED;
+        break;
+    case TWM_EVENT_WINDOW_MINIMIZED:
+        type = SDL_EVENT_WINDOW_MINIMIZED;
+        break;
+    case TWM_EVENT_WINDOW_UNMAXIMIZED:
+    case TWM_EVENT_WINDOW_RESTORED:
+        type = SDL_EVENT_WINDOW_RESTORED;
+        break;
+    }
+
+    SDL_SendWindowEvent(window, type, 0, 0);
+}
+
+void STANIX_PumpEvents(SDL_VideoDevice *_this)
+{
+    twm_event_t *event;
+    while ((event = twm_peek_event())) {
+        switch (event->type) {
+        case TWM_EVENT_INPUT:
+            handle_input_event((twm_event_input_t*)event);
+            break;
+        case TWM_EVENT_WINDOW_CLOSED:
+        case TWM_EVENT_WINDOW_RESIZED:
+        case TWM_EVENT_WINDOW_MAXIMIZED:
+        case TWM_EVENT_WINDOW_UNMAXIMIZED:
+        case TWM_EVENT_WINDOW_MINIMIZED:
+        case TWM_EVENT_WINDOW_RESTORED:
+            handle_window_event((twm_event_window_t*)event);
+            break;
+        case TWM_EVENT_WINDOW_FOCUS:;
+            twm_event_window_t *window_event = (twm_event_window_t*)event;
+            SDL_Window *window = get_window(window_event->window);
+            if (!window) break;
+            SDL_SendWindowEvent(window, SDL_EVENT_WINDOW_FOCUS_GAINED, 0, 0);
+            SDL_SetMouseFocus(window);
+            SDL_SetKeyboardFocus(window);
+            break;
+        case TWM_EVENT_WINDOW_UNFOCUS:
+            window_event = (twm_event_window_t*)event;
+            window = get_window(window_event->window);
+            SDL_SendWindowEvent(window, SDL_EVENT_WINDOW_FOCUS_LOST, 0, 0);
+            SDL_SetMouseFocus(NULL);
+            SDL_SetKeyboardFocus(NULL);
+            break;
+        }
+        free(event);
+    }
+}
+
+#endif // SDL_VIDEO_DRIVER_STANIX
