+static unsigned char ConvertToQuakeKey(struct input_event *event)
+{
+	switch (event->ie_key.scancode) {
+	case 0x01:
+		return K_ESCAPE;
+	case 0x1C:
+		return K_ENTER;
+	case 0x2A:
+	case 0x36:
+		return K_SHIFT;
+	case 0x80 + 0x48:
+		return K_UPARROW;
+	case 0x80 + 0x4B:
+		return K_LEFTARROW;
+	case 0x80 + 0x50:
+		return K_DOWNARROW;
+	case 0x80 + 0x4D:
+		return K_RIGHTARROW;
+	default:
+		return event->ie_key.c;
+	}     
+}
+
+void HandleInput(void)
+{
+	// handle keyboard events
+	struct input_event event;
+	while (libinput_get_event(keyboard_fd, &event) > 0) {
+		// ignore hold
+		if (event.ie_key.flags & IE_KEY_HOLD) continue;
+		Quake2_SendKey(ConvertToQuakeKey(&event), event.ie_key.flags & IE_KEY_PRESS);
+	}
+}
