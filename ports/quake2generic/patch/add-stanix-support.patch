+int QG_Milliseconds(void)
+{	
+	struct timeval  tp;
+	struct timezone tzp;
+
+	gettimeofday(&tp, &tzp);
+
+	return (tp.tv_sec * 1000) + (tp.tv_usec / 1000); /* return milliseconds */
+}
