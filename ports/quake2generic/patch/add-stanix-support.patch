+int main(int argc, char **argv)
+{
+	int time, oldtime, newtime;
+
+	Quake2_Init(argc, argv);
+
+		oldtime = Quake2_Milliseconds ();
+		while (1)
+		{
+			HandleInput();
+			
+			do {
+				newtime = Quake2_Milliseconds ();
+				time = newtime - oldtime;
+			} while (time < 1);
+
+			Quake2_Frame(time);
+			
+			oldtime = newtime;
+		}
+
+		return 0;
+}
