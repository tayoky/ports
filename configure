#!/bin/sh

. ./tconf.sh

tconf_init "$@"

tconf_search_cc "$HOST"
tconf_search_cxx "$HOST"
tconf_search_as "$HOST"
tconf_search_ar "$HOST"
tconf_search_ld "$HOST"
tconf_search_nm "$HOST"
tconf_search_strip "$HOST"
tconf_search_pkgconfig ""

tconf_find_os

tconf_fini

# create meson cross file
# and yes we assume little endian
echo "#generated automatically by ./configure
[binaries]
c   = '$CC'
cpp = '$CXX'
ar  = '$AR'
ld  = '$LD'
as  = '$AS'
strip = '$STRIP'

[host_machine]
system     = '${HOST#*-}'
cpu_family = '${HOST%%-*}'
cpu        = '${HOST%%-*}'
endian     = 'little'
[properties]
sys_root = '$SYSROOT'
" > meson-cross.txt

# now cmake cross file
echo "#generated automatically by ./configure
set(CMAKE_SYSTEM_NAME ${HOST#*-})

set(CMAKE_C_COMPILER   $CC)
set(CMAKE_CXX_COMPILER $CXX)
set(CMAKE_LINKER       $LD)

set(CMAKE_FIND_ROOT_PATH \"$SYSROOT\")

set(CMAKE_FIND_ROOT_PATH_MODE_PROGRAM NEVER)

set(CMAKE_FIND_ROOT_PATH_MODE_LIBRARY ONLY)
set(CMAKE_FIND_ROOT_PATH_MODE_INCLUDE ONLY)" > cmake-cross.cmake
